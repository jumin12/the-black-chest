{
  "buildCommand": "",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/map-editor.html", "destination": "/map-editor.html" },
    { "source": "/site.webmanifest", "destination": "/site.webmanifest" },
    { "source": "/favicon.ico", "destination": "/assets/flags/flag23.png" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
