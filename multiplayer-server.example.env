# Copy values into your process manager (systemd, PM2, Docker `-e`, etc.).
# This file is not loaded automatically — documentation only.
#
# ── Process / host (dedicated VM/VPS) ─────────────────────────────────────────
# Run one Node.js process per realm on a machine with enough RAM for in-memory
# world + WebSocket fan-out. Typical small realm: 1–2 GB free RAM; busier realms:
# scale vertical (CPU + RAM) before adding more players per process.
#
PORT=3000
NODE_ENV=production

# Logical realm (separate processes = separate player caps; not geo-regions).
REALM_ID=main
REALM_NAME=The High Seas
REALM_MOTD=

# World / sim (large STATE_AOI_RADIUS = more work per client per tick — prefer
# more smaller realms over one huge AOI on one box).
WORLD_SEED=

# Concurrent WebSocket logins (0 = unlimited at app level; still limited by RAM/CPU).
MAX_CONCURRENT_CAPTAINS=128

# AOI for `state` payloads: only captains within this radius (world units) are
# sent to each client — cuts JSON size when many players share a world.
STATE_AOI_RADIUS=5200

# Persistence / admin (see server.js for full list)
# DATA_DIR=./data
# SERVER_STATE_SAVE_INTERVAL_MS=60000
# WS_PING_INTERVAL_MS=22000
